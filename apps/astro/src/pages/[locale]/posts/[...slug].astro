---
import BlogLayout from "../../../layouts/BlogLayout.astro";
import "../../../styles/markdown.css";
import { getCollection } from "astro:content";
import type { Locale } from "../../../i18n/ui";
import { getPostTitle, getPostExcerpt, getSwitchLocalePath, useTranslations } from "../../../i18n/utils";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const locales: Locale[] = ['en', 'ja'];
  return locales.flatMap((locale) =>
    posts.map((post) => ({
      params: { locale, slug: post.slug },
      props: { post, locale },
    }))
  );
}

const { post, locale } = Astro.props;
const { Content } = await post.render();

const postTitle = getPostTitle(post.data, locale);
const title = `${postTitle} | Jun Kawasaki`;

const formattedDate = new Date(post.data.date).toLocaleDateString(
  locale === 'ja' ? 'ja-JP' : 'en-US',
  { year: 'numeric', month: 'long', day: 'numeric' }
);

const switchPath = getSwitchLocalePath(Astro.url);
const t = useTranslations(locale);
---

<BlogLayout title={title} description={getPostExcerpt(post.data, locale)} image={post.data.ogImage?.url || post.data.coverImage}>
  <main class="md-body">
    <div class="md-nav-row">
      <p class="md-back-link">
        <a href={`/${locale}/`}>&larr; Jun Kawasaki.</a>
      </p>
      <a href={switchPath} class="md-lang-switch">{t('lang.switch')}</a>
    </div>

    <hr />

    <article>
      <h1 class="md-article-title">{postTitle}</h1>

      <p class="md-article-meta">
        {post.data.author.name} &mdash; <time datetime={post.data.date}>{formattedDate}</time>
      </p>

      <img
        src={post.data.coverImage}
        alt={`Cover Image for ${postTitle}`}
        class="md-article-image"
      />

      <hr />

      <div class="prose">
        <Content />
      </div>
    </article>
  </main>
</BlogLayout>

<style>
  .md-nav-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .md-lang-switch {
    color: #0969da;
    text-decoration: none;
    font-size: 0.875em;
    font-family: 'Poppins', 'Noto Sans JP', ui-sans-serif, system-ui, sans-serif;
    font-weight: 600;
  }

  .md-lang-switch:hover {
    text-decoration: underline;
  }

  :global(body[data-mode="dark"]) .md-lang-switch {
    color: #58a6ff;
  }

  .md-back-link {
    margin: 0;
    font-size: 0.875em;
  }

  .md-back-link a {
    color: #0969da;
    text-decoration: none;
    font-family: 'Noto Sans JP', 'Poppins', ui-sans-serif, system-ui, sans-serif;
    font-weight: 600;
  }

  .md-back-link a:hover {
    text-decoration: underline;
  }

  :global(body[data-mode="dark"]) .md-back-link a {
    color: #58a6ff;
  }

  hr {
    height: 0.25em;
    padding: 0;
    margin: 1.5em 0;
    background-color: #d0d7de;
    border: 0;
  }

  :global(body[data-mode="dark"]) hr {
    background-color: #30363d;
  }

  .md-article-title {
    font-size: 2em;
    font-weight: 600;
    padding-bottom: 0.3em;
    border-bottom: 1px solid #d0d7de;
    margin-top: 0;
    margin-bottom: 0.5em;
    line-height: 1.3;
    font-family: 'Noto Sans JP', 'Poppins', ui-sans-serif, system-ui, sans-serif;
  }

  :global(body[data-mode="dark"]) .md-article-title {
    border-bottom-color: #30363d;
  }

  .md-article-meta {
    color: #57606a;
    font-size: 0.875em;
    margin-bottom: 1.5em;
    font-family: 'Poppins', 'Noto Sans JP', ui-sans-serif, system-ui, sans-serif;
  }

  :global(body[data-mode="dark"]) .md-article-meta {
    color: #8b949e;
  }

  .md-article-image {
    max-width: 100%;
    border-radius: 6px;
    margin-bottom: 0;
  }
</style>
