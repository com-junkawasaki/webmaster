---
import BlogLayout from "../../layouts/BlogLayout.astro";
import Intro from "../../components/Intro.astro";
import HeroPost from "../../components/HeroPost.astro";
import MoreStories from "../../components/MoreStories.astro";
import Career from "../../components/Career.tsx";
import { getCollection } from "astro:content";
import type { Locale } from "../../i18n/ui";
import { getPostTitle, getPostExcerpt } from "../../i18n/utils";

export async function getStaticPaths() {
  return [
    { params: { locale: 'en' } },
    { params: { locale: 'ja' } },
  ];
}

const locale = Astro.params.locale as Locale;
const posts = await getCollection("posts");

const sortedPosts = posts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const heroPost = sortedPosts[0];
const morePosts = sortedPosts.slice(1);

const title = "Jun Kawasaki";
---

<BlogLayout title={title}>
  <main class="md-body">
    <Intro />
    {heroPost && (
      <HeroPost
        title={getPostTitle(heroPost.data, locale)}
        coverImage={heroPost.data.coverImage}
        date={heroPost.data.date}
        author={heroPost.data.author}
        slug={heroPost.slug}
        excerpt={getPostExcerpt(heroPost.data, locale)}
        locale={locale}
      />
    )}
    {morePosts.length > 0 && (
      <MoreStories posts={morePosts} locale={locale} />
    )}
    <Career client:load />
  </main>
</BlogLayout>
