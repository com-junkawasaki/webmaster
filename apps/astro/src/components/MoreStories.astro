---
import { getCollection } from "astro:content";

interface Post {
  slug: string;
  data: {
    title: string;
    date: string;
    author: {
      name: string;
      picture: string;
    };
    excerpt: string;
    coverImage: string;
    ogImage: {
      url: string;
    };
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<section class="mb-32">
  <h2 class="mb-16 text-6xl md:text-8xl font-bold tracking-tighter leading-tight text-slate-900">
    More Stories
  </h2>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
    {posts.map((post) => (
      <article class="group cursor-pointer">
        {/* 記事画像 */}
        <div class="mb-6 overflow-hidden rounded-lg">
          <img
            src={post.data.coverImage}
            alt={`Cover Image for ${post.data.title}`}
            class="w-full h-64 object-cover transition-all duration-200"
          />
        </div>

        {/* 記事情報 */}
        <div class="space-y-4">
          {/* 日付 */}
          <time
            class="text-sm text-slate-600 font-medium"
            dateTime={post.data.date}
          >
            {new Date(post.data.date).toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric'
            })}
          </time>

          {/* タイトル */}
          <h3 class="text-2xl font-bold leading-tight text-slate-900 group-hover:text-blue-600 transition-colors duration-200">
            <a href={`/posts/${post.slug}`} class="hover:underline">
              {post.data.title}
            </a>
          </h3>

          {/* 抜粋 */}
          <p class="text-lg leading-relaxed text-slate-700 line-clamp-3">
            {post.data.excerpt}
          </p>

          {/* 著者情報 */}
          <div class="flex items-center pt-4">
            <img
              src={post.data.author.picture}
              class="w-10 h-10 rounded-full mr-3"
              alt={post.data.author.name}
            />
            <span class="text-sm font-medium text-slate-600">
              {post.data.author.name}
            </span>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
