---
interface Post {
  slug: string;
  data: {
    title: string;
    date: string;
    author: {
      name: string;
      picture: string;
    };
    excerpt: string;
    coverImage: string;
    ogImage: {
      url: string;
    };
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<section class="md-more-stories">
  <h2 class="md-section-heading">Posts</h2>

  <ul class="md-post-list">
    {posts.map((post) => {
      const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
        year: 'numeric',
        month: 'short',
        day: 'numeric'
      });
      return (
        <li class="md-post-item">
          <a href={`/posts/${post.slug}`} class="md-post-link">{post.data.title}</a>
          <span class="md-post-date"> &mdash; {formattedDate}</span>
          <p class="md-post-desc">{post.data.excerpt}</p>
        </li>
      );
    })}
  </ul>
</section>
<hr />

<style>
  .md-section-heading {
    font-size: 1.5em;
    font-weight: 600;
    padding-bottom: 0.3em;
    border-bottom: 1px solid #d0d7de;
    margin-top: 0;
    margin-bottom: 1em;
    font-family: 'Noto Sans JP', 'Poppins', ui-sans-serif, system-ui, sans-serif;
  }

  :global(body[data-mode="dark"]) .md-section-heading {
    border-bottom-color: #30363d;
  }

  .md-post-list {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }

  .md-post-item {
    padding: 0.75em 0;
    border-bottom: 1px solid #d8dee4;
  }

  .md-post-item:last-child {
    border-bottom: none;
  }

  :global(body[data-mode="dark"]) .md-post-item {
    border-bottom-color: #21262d;
  }

  .md-post-link {
    color: #0969da;
    text-decoration: none;
    font-weight: 600;
    font-family: 'Noto Sans JP', 'Poppins', ui-sans-serif, system-ui, sans-serif;
  }

  .md-post-link:hover {
    text-decoration: underline;
  }

  :global(body[data-mode="dark"]) .md-post-link {
    color: #58a6ff;
  }

  .md-post-date {
    color: #57606a;
    font-size: 0.875em;
    font-family: 'Poppins', 'Noto Sans JP', ui-sans-serif, system-ui, sans-serif;
  }

  :global(body[data-mode="dark"]) .md-post-date {
    color: #8b949e;
  }

  .md-post-desc {
    color: #57606a;
    font-size: 0.875em;
    margin: 0.25em 0 0 0;
    line-height: 1.6;
    font-family: 'Poppins', 'Noto Sans JP', ui-sans-serif, system-ui, sans-serif;
  }

  :global(body[data-mode="dark"]) .md-post-desc {
    color: #8b949e;
  }

  hr {
    height: 0.25em;
    padding: 0;
    margin: 1.5em 0;
    background-color: #d0d7de;
    border: 0;
  }

  :global(body[data-mode="dark"]) hr {
    background-color: #30363d;
  }
</style>
